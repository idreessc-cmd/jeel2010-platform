rules_version = '2';

// ==========================================
// Cloud Firestore Security Rules (DRAFT RULES)
// ==========================================
// مسودة قواعد حماية قاعدة البيانات لمنصة امتحان النجاح - جيل 2010
// تم تصميمها لتأمين وصول الطلاب والزوار، ومنع التلاعب بالأدوار أو الاشتراكات.

service cloud.firestore {
  match /databases/{database}/documents {

    // دالات مساعدة (Helper Functions)
    
    // التحقق من تسجيل دخول المستخدم
    function isSignedIn() {
      return request.auth != null;
    }

    // التحقق من أن المستخدم يقرأ أو يكتب بياناته الخاصة فقط
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // التحقق مما إذا كان المستخدم مسؤولاً (Admin) بقراءة وثيقة المستخدم الخاصة به
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. قواعد مستندات المستخدمين (users Collection)
    match /users/{userId} {
      // الطالب والمسؤول يستطيعان قراءة ملف المستخدم المعني
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      // عند التسجيل الجديد: يُسمح للطلب فقط بالتسجيل كطالب عادي وباشتراك مجاني افتراضي أو إذا كان لديه دعوة صالحة
      allow create: if isSignedIn() && isOwner(userId) && 
        request.resource.data.role == 'student' && 
        (
          request.resource.data.subscriptionStatus == 'free' ||
          (
            request.auth.token.email != null &&
            exists(/databases/$(database)/documents/studentInvites/$(request.auth.token.email))
          )
        );
      
      allow update: if isAdmin()
        || (
          isSignedIn()
          && isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.subscriptionStatus == resource.data.subscriptionStatus
          && request.resource.data.subscriptionPlan == resource.data.subscriptionPlan
          && request.resource.data.access == resource.data.access
          && request.resource.data.isActive == resource.data.isActive
        );
      
      // الحذف للمسؤول فقط
      allow delete: if isAdmin();
    }

    // 2. قواعد المواد والوحدات والدروس (المنهج الدراسي)
    match /subjects/{subjectId} {
      allow read: if resource == null || resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    match /units/{unitId} {
      allow read: if resource == null || resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if resource == null || resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // 3. قواعد الامتحانات القصيرة (quizzes Collection)
    match /quizzes/{quizId} {
      allow read: if isSignedIn() || isAdmin();
      allow write: if isAdmin();
    }

    // 4. قواعد محاولات الطلاب في حل الامتحانات (quizAttempts Collection)
    match /quizAttempts/{attemptId} {
      // الطالب يقرأ ويكتب محاولاته الخاصة فقط، والمسؤول يقرأ كل شيء
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 5. قواعد تسجيل التقدم الدراسي للطلاب (studentProgress Collection)
    match /studentProgress/{progressId} {
      // الطالب يقرأ ويسجل تقدمه الدراسي الخاص، والمسؤول يقرأ كل شيء
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
    }

    // 6. قواعد الاشتراكات والمدفوعات والإعلانات
    match /subscriptions/{subId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /payments/{payId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /announcements/{annId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 7. قواعد الدعوات المسبقة للطلاب (studentInvites Collection)
    match /studentInvites/{inviteId} {
      allow read: if isAdmin()
        || (
          isSignedIn()
          && request.auth.token.email != null
          && request.auth.token.email == resource.data.email
        );
      allow create, update, delete: if isAdmin();
    }
  }
}
